using System;
using System.Collections.Generic;
using System.IO;
using Ekz.Models;
using QuestPDF.Fluent;
using QuestPDF.Infrastructure;

namespace Ekz.Services;

public static class PdfService
{
    public static void GenerateTicket(
        Stream stream,
        int orderNumber,
        DateTime orderDate,
        List<OrderItem> items,
        decimal totalAmount,
        decimal discountAmount,
        decimal finalAmount)
    {
        QuestPDF.Settings.License = LicenseType.Community;

        Document.Create(container =>
        {
            container.Page(page =>
            {
                page.Margin(30);

                page.Header().Text($"Талон заказа №{orderNumber}")
                    .FontSize(20)
                    .Bold();

                page.Content().Column(column =>
                {
                    column.Spacing(8);

                    column.Item().Text($"Дата заказа: {orderDate:dd.MM.yyyy HH:mm}");
                    column.Item().Text($"Номер заказа: {orderNumber}");
                    column.Item().Text("Состав заказа:").Bold();

                    foreach (var item in items)
                    {
                        column.Item().Text(
                            $"{item.Product.Name} | Кол-во: {item.Quantity} | Цена: {item.UnitPrice:0.00} | Скидка: {item.DiscountPercent:0.##}% | Сумма: {item.LineTotal:0.00}");
                    }

                    column.Item().PaddingTop(10).Text($"Сумма без скидки: {totalAmount:0.00} руб.");
                    column.Item().Text($"Сумма скидки: {discountAmount:0.00} руб.");
                    column.Item().Text($"Итоговая сумма: {finalAmount:0.00} руб.").Bold();
                });

                page.Footer()
                    .AlignCenter()
                    .Text("Магазин - талон на получение заказа");
            });
        })
        .GeneratePdf(stream);
    }
}



