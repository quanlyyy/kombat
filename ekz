using System;
using System.Collections.ObjectModel;
using System.Collections.Specialized;
using System.IO;
using System.Linq;
using System.Threading.Tasks;
using CommunityToolkit.Mvvm.ComponentModel;
using Ekz.Models;
using Ekz.Services;

namespace Ekz.ViewModels;

public partial class OrderWindowViewModel : ObservableObject
{
    private readonly DatabaseService _dbService;
    private readonly ObservableCollection<OrderItem> _items;
    private bool _isSaved;

    public ObservableCollection<OrderItem> Items => _items;

    [ObservableProperty]
    private int orderNumber;

    [ObservableProperty]
    private DateTime orderDate = DateTime.Now;

    [ObservableProperty]
    private string statusMessage = string.Empty;

    public decimal TotalAmount => Items.Sum(x => x.UnitPrice * x.Quantity);
    public decimal DiscountAmount => Items.Sum(x => x.LineDiscount);
    public decimal FinalAmount => Items.Sum(x => x.LineTotal);

    public OrderWindowViewModel(DatabaseService dbService, ObservableCollection<OrderItem> items)
    {
        _dbService = dbService;
        _items = items;

        _items.CollectionChanged += Items_CollectionChanged;

        foreach (var item in _items)
            item.PropertyChanged += Item_PropertyChanged;

        _ = InitializeAsync();
    }

    private async Task InitializeAsync()
    {
        try
        {
            OrderNumber = await _dbService.GetNextOrderNumber();
            Recalculate();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Ошибка инициализации: {ex.Message}";
        }
    }

    private void Items_CollectionChanged(object? sender, NotifyCollectionChangedEventArgs e)
    {
        if (e.NewItems != null)
        {
            foreach (OrderItem item in e.NewItems)
                item.PropertyChanged += Item_PropertyChanged;
        }

        if (e.OldItems != null)
        {
            foreach (OrderItem item in e.OldItems)
                item.PropertyChanged -= Item_PropertyChanged;
        }

        Recalculate();
    }

    private void Item_PropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(OrderItem.Quantity))
        {
            if (sender is OrderItem item && item.Quantity <= 0)
            {
                _items.Remove(item);
                return;
            }

            Recalculate();
        }
    }

    public void RemoveItem(OrderItem item)
    {
        _items.Remove(item);
        Recalculate();
    }

    public void Recalculate()
    {
        OnPropertyChanged(nameof(TotalAmount));
        OnPropertyChanged(nameof(DiscountAmount));
        OnPropertyChanged(nameof(FinalAmount));
    }

    public async Task<bool> SaveOrderAsync()
    {
        try
        {
            if (_isSaved)
            {
                StatusMessage = "Заказ уже сохранён в БД";
                return true;
            }

            if (!_items.Any())
            {
                StatusMessage = "Заказ пуст";
                return false;
            }

            var validItems = _items.Where(x => x.Quantity > 0).ToList();
            if (!validItems.Any())
            {
                StatusMessage = "Нет товаров для сохранения";
                return false;
            }

            await _dbService.SaveOrder(
                OrderNumber,
                TotalAmount,
                DiscountAmount,
                FinalAmount,
                validItems);

            _isSaved = true;
            StatusMessage = $"Заказ №{OrderNumber} сохранён";
            return true;
        }
        catch (Exception ex)
        {
            StatusMessage = $"Ошибка сохранения заказа: {ex.Message}";
            return false;
        }
    }

    public void GeneratePdf(Stream stream)
    {
        PdfService.GenerateTicket(
            stream,
            OrderNumber,
            OrderDate,
            Items.ToList(),
            TotalAmount,
            DiscountAmount,
            FinalAmount);
    }
}




