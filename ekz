using System;
using System.Collections.ObjectModel;
using System.Collections.Specialized;
using System.Linq;
using System.Threading.Tasks;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using Ekz.Models;
using Ekz.Services;

namespace Ekz.ViewModels;

public partial class MainWindowViewModel : ObservableObject
{
    private readonly DatabaseService _dbService;

    public ObservableCollection<Product> Products { get; } = new();
    public ObservableCollection<OrderItem> CurrentOrder { get; } = new();

    [ObservableProperty]
    private string statusMessage = string.Empty;

    public bool HasOrder => CurrentOrder.Any();

    public event Func<OrderWindowViewModel, Task>? OpenOrderRequested;

    public MainWindowViewModel()
    {
        _dbService = new DatabaseService();

        CurrentOrder.CollectionChanged += CurrentOrder_CollectionChanged;

        LoadProductsCommand.Execute(null);
    }

    private void CurrentOrder_CollectionChanged(object? sender, NotifyCollectionChangedEventArgs e)
    {
        OnPropertyChanged(nameof(HasOrder));
    }

    [RelayCommand]
    private async Task LoadProducts()
    {
        try
        {
            StatusMessage = "Загрузка товаров...";
            var list = await _dbService.GetProducts();

            Products.Clear();
            foreach (var product in list)
                Products.Add(product);

            StatusMessage = $"Загружено товаров: {Products.Count}";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Ошибка загрузки: {ex.Message}";
        }
    }

    [RelayCommand]
    private void AddToOrder(Product product)
    {
        var existing = CurrentOrder.FirstOrDefault(x => x.Product.Id == product.Id);

        if (existing != null)
        {
            existing.Quantity++;
        }
        else
        {
            CurrentOrder.Add(new OrderItem
            {
                Product = product,
                Quantity = 1
            });
        }

        StatusMessage = $"Товар \"{product.Name}\" добавлен к заказу";
        OnPropertyChanged(nameof(HasOrder));
    }

    [RelayCommand]
    private async Task OpenOrder()
    {
        if (!HasOrder)
            return;

        var vm = new OrderWindowViewModel(_dbService, CurrentOrder);

        if (OpenOrderRequested != null)
            await OpenOrderRequested.Invoke(vm);

        OnPropertyChanged(nameof(HasOrder));
    }
}



